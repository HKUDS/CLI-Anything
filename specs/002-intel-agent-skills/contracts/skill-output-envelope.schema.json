{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intel-skill-output-envelope.schema.json",
  "title": "Intel Skill Output Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill_name",
    "contract_version",
    "status",
    "summary",
    "findings",
    "evidence",
    "confidence",
    "next_actions",
    "errors"
  ],
  "properties": {
    "skill_name": {
      "type": "string",
      "enum": [
        "intel-duty-officer",
        "source-health-triage",
        "briefing-analyst"
      ]
    },
    "contract_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "partial",
        "degraded",
        "failed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source",
          "detail"
        ],
        "properties": {
          "source": {
            "type": "string",
            "minLength": 1
          },
          "detail": {
            "type": "string",
            "minLength": 1
          },
          "timestamp": {
            "type": [
              "string",
              "null"
            ]
          },
          "target": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "recoverable": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
