**/__pycache__/
**/*.egg-info/
**/*.pyc
**/dist/
**/build/
**/.pytest_cache/
**/*.egg
**/*.mp4
**/*.wav
**/*.blend
**/*.xcf
**/*.mlt
**/*.drawio

